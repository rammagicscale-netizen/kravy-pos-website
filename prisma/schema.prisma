generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
  SELLER
}

enum FieldType {
  INPUT
  SELECT
  CHECKBOX
  RADIO
  FILE
}

//////////////////////////////////////////////////
// SYSTEM SETTINGS & ROLES
//////////////////////////////////////////////////

model RolePermission {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  role         Role     @unique
  allowedPaths String[] // List of paths or permissions this role is allowed to access
  updatedAt    DateTime @updatedAt
}

//////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////

model Category {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  clerkId String?

  parentId String?    @db.ObjectId
  parent   Category?  @relation("Subcategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("Subcategories")

  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

//////////////////////////////////////////////////
// ITEM
//////////////////////////////////////////////////

model Item {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  price        Float?
  sellingPrice Float?
  gst          Float?
  unit         String?
  barcode      String?
  taxStatus    String? // "With Tax" or "Without Tax"
  imageUrl     String?
  image        String? // ✅ THIS MUST EXIST

  categoryId String?   @db.ObjectId
  category   Category? @relation(fields: [categoryId], references: [id])

  clerkId String
  userId  String @db.ObjectId

  isActive Boolean @default(true)

  // Inventory Details
  openingStock Float? @default(0)
  currentStock Float? @default(0)
  reorderLevel Float? @default(0)

  // QR Menu Enhancements
  isVeg         Boolean @default(true)
  isEgg         Boolean @default(false)
  isBestseller  Boolean @default(false)
  isRecommended Boolean @default(false)
  isNew         Boolean @default(false)
  spiciness     String? // mild, medium, hot
  rating        Float?  @default(4.5)
  hiName        String?
  mrName        String?
  taName        String?
  upsellText    String?
  hsnCode       String?
  variants      Json? // List of { id, groupName, type ('radio'|'checkbox'), required, options: [{id, name, price}] }
  tags          String[] // e.g. ["bestseller", "spicy"]
  
  packagingCharges Float? @default(0)
  gstType          String? // GOODS, SERVICES
  taxRate          String? // GST 5.0% etc
  calories         Float?
  protein          Float?

  // Relationship to AddonGroups
  addonGroups   AddonGroup[] @relation("ItemToAddonGroups", fields: [addonGroupIds], references: [id])
  addonGroupIds String[]     @db.ObjectId

  user User @relation(fields: [userId], references: [id])

  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model AddonGroup {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId           String?
  userId            String   @db.ObjectId
  name              String
  isCompulsory      Boolean  @default(false)
  minSelection      Int      @default(0)
  maxSelection      Int      @default(5)
  allowMultipleUnits Boolean  @default(false)
  items             Json     // List of { name, price, foodType, isAvailable }

  // Many-to-many with items
  itemsOnMenu       Item[]   @relation("ItemToAddonGroups", fields: [itemIds], references: [id])
  itemIds           String[] @db.ObjectId

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

//////////////////////////////////////////////////
// PARTY (CUSTOMER)
//////////////////////////////////////////////////

model Party {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  address   String?
  dob       DateTime?
  createdBy String
  user      User?     @relation(fields: [createdBy], references: [clerkId])

  loyaltyPoints Int @default(0)
  walletBalance Float @default(0.0) // Added for Deposit/Wallet System

  bills BillManager[]
  walletTransactions WalletTransaction[] // Added relation

  createdAt DateTime @default(now())

  @@unique([phone, createdBy])
}

//////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////

model Payment {
  id     String      @id @default(auto()) @map("_id") @db.ObjectId
  billId String      @db.ObjectId
  bill   BillManager @relation(fields: [billId], references: [id])

  amount Float
  mode   String
  txnRef String?
  paidAt DateTime @default(now())
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  email   String @unique
  clerkId String @unique
  role    Role   @default(SELLER)

  items    Item[]
  bills    BillManager[]
  parties  Party[]
  forms    Form[]
  profiles BusinessProfile[]
  uploads  Upload[]
  addonGroups AddonGroup[]

  isDisabled   Boolean  @default(false)
  ownerId      String?
  allowedPaths String[]

  uiPreferences Json? @default("{}")

  createdAt DateTime @default(now())

  activities ActivityLog[]
  orders     Order[]
  tables     Table[]
  combos     Combo[]
  offers     Offer[]
  rewards    Reward[]
}

//////////////////////////////////////////////////
// TABLE
//////////////////////////////////////////////////

model Table {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  qrUrl       String? // persisted QR code image URL (150x150) for this table
  clerkUserId String
  user        User     @relation(fields: [clerkUserId], references: [clerkId])
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clerkUserId])
}

//////////////////////////////////////////////////
// ORDER (from QR Menu)
//////////////////////////////////////////////////

model Order {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId String
  user        User   @relation(fields: [clerkUserId], references: [clerkId])

  tableId String? @db.ObjectId
  table   Table?  @relation(fields: [tableId], references: [id])

  items Json // Array of { name, price, quantity, itemId, addedAt, addedInCase }
  total Float

  status String @default("PENDING") // PENDING, ACCEPTING, ACCEPTED, PREPARING, READY, SERVED, COMPLETED

  // For Case 1 (Merge)
  parentOrderId String?   @db.ObjectId
  caseType      String? // "merge", "separate", "round2"
  isMerged      Boolean   @default(false)
  mergedAt      DateTime?

  // For Case 2 (Separate) - Track related orders
  relatedOrders String[] @db.ObjectId // Array of order IDs in same session

  customerName    String?
  customerPhone   String?
  customerAddress String? // ✅ Added for home delivery / address tracking
  paymentMode     String? // UPI, CASH, CARD intent from QR menu

  isKotPrinted  Boolean @default(false)
  isBillPrinted Boolean @default(false)

  notes       String? // ✅ Global order instructions
  preferences Json?   // ✅ Added for preferences like { dontSendCutlery: true }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])
  @@index([status])
}

//////////////////////////////////////////////////
// REVIEW
//////////////////////////////////////////////////

model Review {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  itemId       String?  @db.ObjectId
  item         Item?    @relation(fields: [itemId], references: [id])
  clerkUserId  String
  rating       Int
  comment      String?
  customerName String?
  tableId      String?
  imageUrl     String?
  createdAt    DateTime @default(now())
}

//////////////////////////////////////////////////
// FORM BUILDER
//////////////////////////////////////////////////

model Form {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  fields    Field[]
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Field {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  formId    String    @db.ObjectId
  form      Form      @relation(fields: [formId], references: [id])
  label     String
  type      FieldType
  required  Boolean   @default(false)
  options   String[]
  value     String?
  createdAt DateTime  @default(now())
}

//////////////////////////////////////////////////
// BUSINESS PROFILE
//////////////////////////////////////////////////

model BusinessProfile {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique
  user   User   @relation(fields: [userId], references: [clerkId])

  businessType    String?
  businessName    String?
  businessTagLine String?

  contactPersonName  String?
  contactPersonPhone String?
  contactPersonEmail String?

  upi             String?
  upiQrEnabled    Boolean @default(true)
  menuLinkEnabled Boolean @default(true)

  profileImageUrl String?
  logoUrl         String?
  signatureUrl    String?

  gstNumber            String?
  businessAddress      String?
  state                String?
  district             String?
  pinCode              String?
  taxEnabled           Boolean @default(true)
  taxRate              Float   @default(5.0)
  gstType              String? @default("PRODUCT") // "PRODUCT" or "UNIVERSAL"
  perProductTaxEnabled Boolean @default(false)

  // ✅ Customer Data Requirement Settings
  collectCustomerName    Boolean @default(true)
  requireCustomerName    Boolean @default(false)
  collectCustomerPhone   Boolean @default(true)
  requireCustomerPhone   Boolean @default(false)
  collectCustomerAddress Boolean @default(false)
  requireCustomerAddress Boolean @default(false)

  greetingMessage  String? @default("Thank You 🙏 Visit Again!")
  businessNameSize String? @default("large") // medium, large, xlarge

  fssaiNumber  String?
  fssaiEnabled Boolean @default(false)
  hsnEnabled   Boolean @default(false)
  
  // ✅ Loyalty Program Settings
  loyaltyPointRatio Float @default(10.0) // 1 point per X rupees
  loyaltyMinRedeem  Int   @default(100)  // Minimum points to unlock reward

  qrMenuPriceInclusive Boolean @default(false)
  enableKOTWithBill    Boolean @default(false)
  enableMenuQRInBill   Boolean @default(false)
  aiScraperEnabled   Boolean @default(false)
  excelImportEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////
// UPLOAD
//////////////////////////////////////////////////

model Upload {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId])
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////
// ActivityLog
//////////////////////////////////////////////////

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  meta      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////
// BillManager
//////////////////////////////////////////////////

model BillManager {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  clerkUserId String
  user        User   @relation(fields: [clerkUserId], references: [clerkId])

  billNumber String
  createdAt  DateTime @default(now())

  items Json

  subtotal       Float
  discountAmount Float?  @default(0)
  discountCode   String?
  tax            Float?
  total          Float

  paymentMode   String
  paymentStatus String
  upiTxnRef     String?
  isHeld        Boolean @default(false)

  customerName    String?
  customerPhone   String?
  customerAddress String? // ✅ Added for home delivery / address tracking
  buyerGSTIN      String?
  placeOfSupply   String?

  isKotPrinted Boolean @default(false) // ✅ Added KOT status

  partyId String? @db.ObjectId
  party   Party?  @relation(fields: [partyId], references: [id])

  payments Payment[] // ✅ ADD THIS

  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  deletedSnapshot Json?
  pdfUrl          String? // ✅ Added for direct sharing
  tableName       String? // ✅ Added to track source (Table Name or "POS")
  auditNote       String? // SaaS Feature: Audit trail for tax corrections

  // WhatsApp Tracking
  whatsappSent   Boolean   @default(false)
  whatsappSentAt DateTime?
  whatsappSid    String?

  @@unique([clerkUserId, billNumber]) // ✅ FIX: Global uniqueness changed to per-business uniqueness
  @@index([clerkUserId])
  @@index([isDeleted, createdAt])
}

//////////////////////////////////////////////////
// COMBO
//////////////////////////////////////////////////

model Combo {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Float
  imageUrl    String?
  clerkUserId String
  user        User    @relation(fields: [clerkUserId], references: [clerkId])
  isActive    Boolean @default(true)

  // Array of selections
  // e.g., [{ type: 'fixed', itemId: '...', qty: 1 }, { type: 'choice', categoryId: '...', label: 'Pick a Beverage' }]
  selections Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])
}

//////////////////////////////////////////////////
// OFFER / COUPON
//////////////////////////////////////////////////

model Offer {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  code          String? @unique
  discountType  String // "PERCENTAGE", "FLAT", "BOGO", "ITEM_WISE"
  discountValue Float? // 0 for BOGO

  // Advanced Rules
  minOrderValue Float? @default(0)
  maxDiscount   Float?

  // BOGO / Item-wise rules
  buyItemId       String? @db.ObjectId // Item to buy
  buyQty          Int?    @default(1)
  getItemOffId    String? @db.ObjectId // Item given off
  getQty          Int?    @default(1)
  getDiscount     Float?  @default(100)
  applyOnCategory String? // For Item-wise category discount

  startDate DateTime?
  endDate   DateTime?

  usageLimit   Int? @default(1000)
  currentUsage Int  @default(0)

  isActive    Boolean @default(true)
  clerkUserId String
  user        User    @relation(fields: [clerkUserId], references: [clerkId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])
}

//////////////////////////////////////////////////
// REWARD (Loyalty Redemption)
//////////////////////////////////////////////////

model Reward {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  pointsRequired Int
  isActive       Boolean @default(true)
  clerkUserId    String
  user           User    @relation(fields: [clerkUserId], references: [clerkId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])
}

model GalleryImage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId String
  imageUrl    String
  category    String   @default("food") // food | interior | promo | other
  caption     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([clerkUserId])
  @@index([clerkUserId, category])
}

model Backup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  filename  String
  fileSize  Int // in bytes
  s3Url     String?
  status    String // SUCCESS, FAILED
  error     String?
  createdAt DateTime @default(now())
}
model Staff {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String?
  email       String   @unique
  password    String?
  accessType  String
  permissions String[]
  businessId  String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

//////////////////////////////////////////////////
// WALLET TRANSACTION
//////////////////////////////////////////////////

model WalletTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  partyId     String   @db.ObjectId
  party       Party    @relation(fields: [partyId], references: [id])
  clerkId     String   // The business owner ID
  type        String   // "CREDIT" (Deposit) | "DEBIT" (Payment)
  amount      Float
  description String?  // e.g., "Order #123" or "Manual Deposit"
  createdAt   DateTime @default(now())

  @@index([partyId])
  @@index([clerkId])
}
